@prefix vocab:<https://vucis.github.io/vocab.ttl#>.
@prefix data:<https://vucis.github.io/data.ttl#>.
@prefix xsd:<http://www.w3.org/2001/XMLSchema>.

data:me a vocab:Person;
  vocab:name "Siebe Vlietinck";
  vocab:knows <https://arnedierick.github.io/data.ttl#me>,
    <https://miboelae.github.io/data.ttl#me>,
    <https://cornelka.github.io/sol_kc/data.ttl#karelcornelis>;
  vocab:gender "male";
  vocab:studentOf <https://pietercolpaert.be/#me>;
  vocab:likes "reading";
  vocab:participantOf vocab:KnowledgeGraphs.

data:KnowledgeGraphs a vocab:Course ;
  vocab:courseName "Knowledge Graphs"^^xsd:string .
  
<https://vtk.ugent.be/media/thumbs/photologue/photos/jobfair-2026-cv-fotos_61_r6m33292.jpg.1920x1005_q85_crop-scale.jpg> a vocab:Image;
  vocab:title "Jobfair 2026 photo";
  vocab:author "VTK Gent";
  vocab:depicts data:me;
  vocab:location "Flanders Expo Gent";
  vocab:description "A photo of Siebe Vlietinck taken at the VTK Jobfair in 2026".


